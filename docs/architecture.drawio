        </mxCell>
        <mxCell id="sw_proxy" value="⚙️ Proxy" style="shape=mxgraph.basic.rect;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=12;rounded=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="740" y="20" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="sw_llm" value="🤖 LLM" style="shape=mxgraph.basic.rect;fillColor=#e6d0de;strokeColor=#996185;fontStyle=1;fontSize=12;rounded=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="980" y="20" width="120" height="40" as="geometry" />
        </mxCell>
        <!-- Vertical lifelines -->
        <mxCell id="life_user" style="strokeColor=#6c8ebf;dashed=1;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="100" y="60" as="sourcePoint" />
            <mxPoint x="100" y="1050" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="life_app" style="strokeColor=#82b366;dashed=1;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="320" y="60" as="sourcePoint" />
            <mxPoint x="320" y="1050" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="life_idb" style="strokeColor=#d6b656;dashed=1;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="560" y="60" as="sourcePoint" />
            <mxPoint x="560" y="1050" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="life_proxy" style="strokeColor=#b85450;dashed=1;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="800" y="60" as="sourcePoint" />
            <mxPoint x="800" y="1050" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="life_llm" style="strokeColor=#996185;dashed=1;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1040" y="60" as="sourcePoint" />
            <mxPoint x="1040" y="1050" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- Step 1: User types message -->
        <mxCell id="s1" value="1. Types message" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#333;strokeWidth=2;fontSize=10;fontStyle=0;endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="100" y="100" as="sourcePoint" />
            <mxPoint x="320" y="100" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- Step 2: Store user message -->
        <mxCell id="s2" value="2. Store user message" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#333;strokeWidth=1;fontSize=10;fontStyle=0;endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="320" y="150" as="sourcePoint" />
            <mxPoint x="560" y="150" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- Step 3: POST /api/chat -->
        <mxCell id="s3" value="3. POST /api/chat&#xa;Headers: X-LLM-Provider,&#xa;X-LLM-Model, X-LLM-API-Key, X-Agent" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#333;strokeWidth=2;fontSize=10;fontStyle=0;endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="320" y="210" as="sourcePoint" />
            <mxPoint x="800" y="210" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- Step 4: Proxy resolves provider -->
        <mxCell id="s4_box" value="4. Resolve LLM provider&#xa;Load agent system prompt&#xa;Render Handlebars templates" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="710" y="250" width="180" height="60" as="geometry" />
        </mxCell>
        <!-- Step 5: streamText to LLM -->
        <mxCell id="s5" value="5. streamText()&#xa;model + tool schemas" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#333;strokeWidth=2;fontSize=10;fontStyle=0;endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="800" y="340" as="sourcePoint" />
            <mxPoint x="1040" y="340" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- Step 6: Token stream back -->
        <mxCell id="s6" value="6. Token stream" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#996185;strokeWidth=1;fontSize=10;fontStyle=0;endArrow=block;endFill=1;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1040" y="390" as="sourcePoint" />
            <mxPoint x="800" y="390" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- Step 7: SSE stream to browser -->
        <mxCell id="s7" value="7. SSE stream (text deltas)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#82b366;strokeWidth=2;fontSize=10;fontStyle=0;endArrow=block;endFill=1;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="800" y="440" as="sourcePoint" />
            <mxPoint x="320" y="440" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- Step 8: Render -->
        <mxCell id="s8_box" value="8. Render streaming&#xa;response in chat UI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="230" y="470" width="180" height="40" as="geometry" />
        </mxCell>
        <!-- Step 9: Store assistant message -->
        <mxCell id="s9" value="9. Store assistant message" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#333;strokeWidth=1;fontSize=10;fontStyle=0;endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="320" y="540" as="sourcePoint" />
            <mxPoint x="560" y="540" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- Divider: Tool call path -->
        <mxCell id="divider" value="If LLM requests a tool call..." style="text;html=1;strokeColor=#666;fillColor=#f5f5f5;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11;fontStyle=3;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="590" width="1100" height="30" as="geometry" />
        </mxCell>
        <!-- Step 10: Tool call in stream -->
        <mxCell id="s10" value="10. Tool call event via SSE" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#b85450;strokeWidth=2;fontSize=10;fontStyle=0;endArrow=block;endFill=1;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="800" y="660" as="sourcePoint" />
            <mxPoint x="320" y="660" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- Step 11: Execute tool -->
        <mxCell id="s11_box" value="11. Execute MCP tool&#xa;(see MCP flow diagram)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="230" y="690" width="180" height="40" as="geometry" />
        </mxCell>
        <!-- Step 12: Return tool result -->
        <mxCell id="s12" value="12. POST /api/chat&#xa;with tool result" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#333;strokeWidth=2;fontSize=10;fontStyle=0;endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="320" y="770" as="sourcePoint" />
            <mxPoint x="800" y="770" as="targetPoint" />
