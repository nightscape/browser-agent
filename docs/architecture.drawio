        </mxCell>
        <mxCell id="sw_idb" value="💾 IndexedDB" style="shape=mxgraph.basic.rect;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=12;rounded=1;arcSize=10;" vertex="1" parent="1">
